# Telegram API credentials — get from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Session file name for the userbot (no .session extension needed)
USERBOT_SESSION=userbot

# Comma-separated list of Telegram user IDs allowed to use the bot
# Leave empty to deny everyone (strict whitelist — at least one ID required)
ADMIN_IDS=123456789,987654321

# SQLite database file path
DB_PATH=telegram_reload.db

# Delay in seconds between transfers (to avoid flood limits)
# A random ±0.5s jitter is added automatically to avoid fixed-interval detection
TRANSFER_DELAY=1.5

# Set to any non-empty value if the userbot account has Telegram Premium
# Enables >2GB uploads and uncapped download speed
IS_PREMIUM=

# Max queued prepared uploads waiting for transfer_bulk() consumers
# This is queue backpressure, not a direct worker-count knob
CONCURRENT_TRANSFERS=3

# Directory for the LRU disk cache of downloaded media files
CACHE_DIR=cache

# Maximum total size of the cache directory in bytes (default: 1 GB)
# Files are evicted in LRU order when this limit is exceeded
MAX_CACHE_SIZE=1073741824

# Max total bytes of prepared inflight media allowed to wait in the bulk queue
# Defaults to MAX_CACHE_SIZE when unset in real config
MAX_INFLIGHT_BYTES=1073741824

# Parallel part workers for large file uploads (>10 MB)
UPLOAD_WORKERS=4

# MTProto sender connections available for upload fanout
SENDER_POOL_SIZE=4

# Note: ffmpeg must be installed on the system for video conversion
# Install with: apt install ffmpeg  OR  brew install ffmpeg
